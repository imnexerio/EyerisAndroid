    <fragment
        android:id="@+id/permissions_fragment"
        android:name="com.imnexerio.eyeris.fragments.PermissionsFragment"
        android:label="PermissionsFragment">
        <action
            android:id="@+id/action_permissions_fragment_to_Analytics_fragment"
            app:destination="@id/Analytics_fragment" />
    </fragment>

    <fragment
        android:id="@+id/camera_fragment"
        android:name="com.imnexerio.eyeris.fragments.CameraFragment"
        android:label="CameraFragment"/>

    <fragment
        android:id="@+id/Analytics_fragment"
        android:name="com.imnexerio.eyeris.fragments.Analyticsfragment"
        android:label="AnalyticsFragment">
        <action
            android:id="@+id/action_Analytics_fragment_to_permissions_fragment"
            app:destination="@id/permissions_fragment" />
    </fragment>

    <fragment
        android:id="@+id/Exercises_fragment"
        android:name="com.imnexerio.eyeris.fragments.ExercisesFragment"
